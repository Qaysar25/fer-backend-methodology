								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/dashboard/stats",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"dashboard",
								"stats"
							]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "Model",
			"item": [
